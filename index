<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JavaCompilerPro - Online Editor</title>
    <style>
        :root { --editor-bg: #1e1e1e; --console-bg: #000; --accent: #4caf50; --text: #d4d4d4; }
        body { margin: 0; font-family: 'Consolas', monospace; background: #2d2d2d; color: var(--text); height: 100vh; display: flex; flex-direction: column; }
        
        /* Navbar */
        nav { background: #333; padding: 10px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #444; }
        .compile-btn { background: var(--accent); color: white; border: none; padding: 8px 25px; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 14px; }
        .compile-btn:hover { background: #45a049; }

        /* Workspace */
        .workspace { display: flex; flex: 1; overflow: hidden; }
        .pane { flex: 1; display: flex; flex-direction: column; position: relative; }
        .pane-header { background: #252526; padding: 5px 15px; font-size: 12px; color: #888; text-transform: uppercase; border-bottom: 1px solid #333; }
        
        /* Editor & Console */
        textarea { flex: 1; background: var(--editor-bg); color: #9cdcfe; border: none; padding: 20px; font-family: 'Consolas', monospace; font-size: 16px; outline: none; resize: none; }
        #console { flex: 1; background: var(--console-bg); color: #fff; padding: 20px; font-size: 15px; overflow-y: auto; white-space: pre-wrap; }
        
        .line-numbers { position: absolute; left: 0; top: 35px; width: 30px; color: #555; text-align: center; font-size: 14px; pointer-events: none; }
    </style>
</head>
<body>

<nav>
    <div style="color: var(--accent); font-weight: bold;">JAVA ONLINE COMPILER <span style="color: #666; font-weight: normal; margin-left: 10px;">main.java</span></div>
    <button class="compile-btn" onclick="compileCode()">▶ RUN / COMPILE</button>
</nav>

<div class="workspace">
    <div class="pane" style="border-right: 2px solid #444;">
        <div class="pane-header">Editor (Type number or topic)</div>
        <textarea id="editor" placeholder="// Type a number (1-20) here and click Compile..."></textarea>
    </div>
    
    <div class="pane">
        <div class="pane-header">Output Console</div>
        <div id="console">> Ready...</div>
    </div>
</div>

<script>
    // Data extracted from jaava.pdf 
    const programLibrary = {
        "1": { code: "public class HelloWorld {\n  public static void main(String[] args) {\n    System.out.println(\"Hello, World!\");\n  }\n}", output: "Hello, World!" },
        "2": { code: "public class AddTwoNumbers {\n  public static void main(String[] args) {\n    int number1 = 5, number2 = 10;\n    int sum = number1 + number2;\n    System.out.println(\"The sum is: \" + sum);\n  }\n}", output: "The sum is: 15" },
        "7": { code: "public class PrimeCheck {\n  public static void main(String[] args) {\n    int num = 29;\n    boolean isPrime = true;\n    for (int i = 2; i <= num / 2; i++) {\n      if (num % i == 0) { isPrime = false; break; }\n    }\n    System.out.println(num + \" is a Prime number.\");\n  }\n}", output: "29 is a Prime number." },
        "prime": { code: "// Prime logic loaded...\n(See code above)", output: "29 is a Prime number." },
        "8": { code: "public class PalindromeNumber {\n  public static void main(String[] args) {\n    int num = 121, original = num, reverse = 0;\n    while (num > 0) {\n      int digit = num % 10;\n      reverse = reverse * 10 + digit;\n      num = num / 10;\n    }\n    System.out.println(original + \" is a Palindrome.\");\n  }\n}", output: "121 is a Palindrome." }
    };

    function compileCode() {
        const editor = document.getElementById('editor');
        const consoleOut = document.getElementById('console');
        const input = editor.value.trim().toLowerCase();

        consoleOut.innerHTML = "<span style='color: #888;'>Compiling...</span>";

        setTimeout(() => {
            if (programLibrary[input]) {
                const program = programLibrary[input];
                editor.value = program.code; // Automatically adds code to section
                consoleOut.innerHTML = "<span style='color: #4caf50;'>Compilation Successful.</span>\n\n" + program.output;
            } else {
                consoleOut.innerHTML = "<span style='color: #f44747;'>Error: Main method not found or invalid input.\nTry entering '1', '2', or '7'.</span>";
            }
        }, 600);
    }
</script>

</body>
</html>
